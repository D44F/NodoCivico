<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.android.nodocivico.ui.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splashFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.android.nodocivico.ui.LoginFragment"
        android:label="Identificación">
        <argument
            android:name="userName"
            app:argType="string" />
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.android.nodocivico.ui.HomeFragment"
        android:label="Inicio">

        <action
            android:id="@+id/action_homeFragment_to_createReportFragment"
            app:destination="@id/createReportFragment" />

        <action
            android:id="@+id/action_homeFragment_to_reportListFragment"
            app:destination="@id/reportListFragment" />

        <action
            android:id="@+id/action_homeFragment_to_syncStatusFragment"
            app:destination="@id/syncStatusFragment" />

        <action
            android:id="@+id/action_homeFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />

    </fragment>

    <fragment
        android:id="@+id/createReportFragment"
        android:name="com.android.nodocivico.ui.CreateReportFragment"
        android:label="Nuevo reporte">

        <action
            android:id="@+id/action_createReportFragment_to_reportListFragment"
            app:destination="@id/reportListFragment" />

    </fragment>

    <fragment
        android:id="@+id/reportListFragment"
        android:name="com.android.nodocivico.ui.ReportListFragment"
        android:label="Reportes">

        <action
            android:id="@+id/action_reportListFragment_to_reportDetailFragment"
            app:destination="@id/reportDetailFragment" />

    </fragment>

    <fragment
        android:id="@+id/reportDetailFragment"
        android:name="com.android.nodocivico.ui.ReportDetailFragment"
        android:label="Detalle del reporte">
        <action
            android:id="@+id/action_reportDetailFragment_to_editReportFragment"
            app:destination="@id/editReportFragment" />
    </fragment>

    <fragment
        android:id="@+id/editReportFragment"
        android:name="com.android.nodocivico.ui.EditReportFragment"
        android:label="Editar reporte" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.android.nodocivico.ui.SettingsFragment"
        android:label="Preferencias" />

    <fragment
        android:id="@+id/syncStatusFragment"
        android:name="com.android.nodocivico.ui.SyncStatusFragment"
        android:label="Sincronización" />

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.android.nodocivico.ui.MapFragment"
        android:label="Mapa" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.android.nodocivico.ui.ProfileFragment"
        android:label="Perfil" />

    <fragment
        android:id="@+id/calendarRemindersFragment"
        android:name="com.android.nodocivico.ui.CalendarRemindersFragment"
        android:label="Recordatorios" />

</navigation>