<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.android.nodocivico.ui.HomeFragment"
        android:label="Inicio">

        <action
            android:id="@+id/action_homeFragment_to_createReportFragment"
            app:destination="@id/createReportFragment" />

        <action
            android:id="@+id/action_homeFragment_to_reportListFragment"
            app:destination="@id/reportListFragment" />

        <action
            android:id="@+id/action_homeFragment_to_syncStatusFragment"
            app:destination="@id/syncStatusFragment" />

        <action
            android:id="@+id/action_homeFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />

    </fragment>

    <fragment
        android:id="@+id/createReportFragment"
        android:name="com.android.nodocivico.ui.CreateReportFragment"
        android:label="Nuevo reporte">

        <action
            android:id="@+id/action_createReportFragment_to_reportListFragment"
            app:destination="@id/reportListFragment" />

    </fragment>

    <fragment
        android:id="@+id/reportListFragment"
        android:name="com.android.nodocivico.ui.ReportListFragment"
        android:label="Reportes">

        <action
            android:id="@+id/action_reportListFragment_to_reportDetailFragment"
            app:destination="@id/reportDetailFragment" />

    </fragment>

    <fragment
        android:id="@+id/reportDetailFragment"
        android:name="com.android.nodocivico.ui.ReportDetailFragment"
        android:label="Detalle del reporte" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.android.nodocivico.ui.SettingsFragment"
        android:label="Preferencias" />

    <fragment
        android:id="@+id/syncStatusFragment"
        android:name="com.android.nodocivico.ui.SyncStatusFragment"
        android:label="Sincronización" />

</navigation>